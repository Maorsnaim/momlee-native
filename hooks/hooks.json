{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/worklog-hook.js\" track"
          }
        ]
      },
      {
        "matcher": "mcp__.*Notion.*(create-pages|update-page)",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/worklog-hook.js\" clear"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/worklog-hook.js\" gate"
          }
        ]
      }
    ]
  }
}
